{
  "name": "kitty-farm",
  "version": "2.0.0",
  "description": "小猫农场 - 键盘池塘挂机养猫游戏（全局监听+浮窗吸附）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64"
  },
  "author": "Kitty Farm",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "@nut-tree/nut-js": "^4.0.0",
    "node-global-key-listener": "^0.3.0"
  },
  "build": {
    "appId": "com.kittyfarm.game",
    "productName": "小猫农场",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-便携版-${version}.exe"
    },
    "files": [
      "**/*",
      "!node_modules/.bin",
      "!*.map"
    ],
    "extraResources": [
      {
        "from": "sounds/",
        "to": "sounds",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
